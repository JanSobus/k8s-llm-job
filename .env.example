APP_LLM_PROVIDER=openai
APP_LLM_FAKE_MODE=true

APP_OPENAI_API_KEY=
APP_OPENAI_BASE_URL=https://api.openai.com/v1
APP_OPENAI_MODEL=gpt-4o-mini

APP_OLLAMA_BASE_URL=http://localhost:11434/v1
APP_OLLAMA_MODEL=qwen2.5:0.5b

APP_KSERVE_BASE_URL=http://vllm-predictor.default.svc.cluster.local/v1
APP_KSERVE_MODEL=Qwen/Qwen2.5-0.5B-Instruct

APP_MINIO_ENDPOINT=http://localhost:9000
APP_MINIO_CONSOLE_URL=http://localhost:9001
APP_MINIO_ACCESS_KEY=minioadmin
APP_MINIO_SECRET_KEY=minioadmin
APP_MINIO_BUCKET=cern-ml-demo
APP_MINIO_SECURE=false
APP_UPLOAD_MAX_BYTES=10485760
APP_ALLOWED_UPLOAD_MIME_TYPES='["application/pdf","text/csv","application/csv","application/vnd.ms-excel"]'
APP_MAX_CONCURRENT_JOBS=5

# Job execution: local (in-process thread pool after upload) or kubernetes (Batch Job)
APP_JOB_EXECUTION_MODE=local
APP_WORKER_IMAGE_PDF=cern-ml-demo-worker-pdf:local
APP_WORKER_IMAGE_TABULAR=cern-ml-demo-worker-tabular:local
APP_KUBERNETES_NAMESPACE=default
APP_JOB_TTL_SECONDS_AFTER_FINISHED=600
APP_JOB_NAME_PREFIX=cern-ml-demo-wk-
APP_BACKEND_KUBERNETES_IN_CLUSTER=false
# APP_KUBECONFIG_PATH=C:\path\to\kubeconfig
